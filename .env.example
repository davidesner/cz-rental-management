# --- Local development -------------------------------------------------------
# Local Postgres via Docker (`rental-pg` container)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rental_dev
BETTER_AUTH_SECRET=replace-me-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000
PORT=3000

# --- Production (Vercel) — set these in Vercel project env vars, not in .env --
# DATABASE_URL=postgres://user:pass@ep-xxx-pooler.<region>.aws.neon.tech/<db>?sslmode=require
# BETTER_AUTH_SECRET=<32+ random bytes — `openssl rand -base64 32`>
# BETTER_AUTH_URL=https://<your-app>.vercel.app
# Note: PORT is not used on Vercel; serverless functions don't bind ports.
# Note: VERCEL=1 is set automatically by Vercel runtime — code uses it to switch to
#       serverless-safe DB pool (max: 1, prepare: false for PgBouncer compat).
