    "fastmcp": "^4.0.1",
    "hono": "^4.12.23",
    "lucide-react": "^1.17.0",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.77.0",
