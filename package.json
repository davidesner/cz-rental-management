{
  "name": "rental-management",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,magenta \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:api": "tsx watch server/node.ts",
    "dev:web": "vite",
    "mcp": "tsx mcp/index.ts",
    "build": "tsc --noEmit",
    "vercel-build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx core/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "test:e2e": "playwright test"
  },
